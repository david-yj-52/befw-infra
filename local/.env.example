# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tsh_super_1234!
POSTGRES_DB=tsh_dev
APP_DB_USER=tsh_app
APP_DB_PASSWORD=tsh_app_1234!
