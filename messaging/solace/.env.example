# =============================================
# Solace PubSub+ Configuration
# cp .env.example .env 후 실제 값 입력
# =============================================

SOLACE_ADMIN_PASSWORD=your_admin_password_here

# 포트
SOLACE_SMF_PORT=55555       # SMF 프로토콜 (Spring Cloud Stream / Java API)
SOLACE_MQTT_PORT=1883       # MQTT
SOLACE_AMQP_PORT=5672       # AMQP
SOLACE_REST_PORT=9000       # REST API
SOLACE_MGMT_PORT=8080       # 관리 Web UI
